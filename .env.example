# DataStax Astra DB Configuration
# Copy this file to .env and fill in your actual values

# Path to your Astra Secure Connect Bundle zip.
ASTRA_SECURE_CONNECT_BUNDLE=./secure-connect-your-database.zip

# Client credentials from your Astra DB.
# For token auth, use ASTRA_CLIENT_ID=token and ASTRA_CLIENT_SECRET=AstraCS:...
ASTRA_CLIENT_ID=token

# Client secret from your Astra DB
ASTRA_CLIENT_SECRET=AstraCS:your-application-token
